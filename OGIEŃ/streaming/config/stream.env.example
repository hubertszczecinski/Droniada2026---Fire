# Skopiuj jako config/stream.env (nie commituj — zawiera klucze)

# --- Odbiór UDP (Gigabyte) ---
UDP_PORT=5600
# H264 | H265
RTP_CODEC=H264
RTP_PAYLOAD=96
UDP_BIND=0.0.0.0

# --- Podgląd lokalny na Gigabyte ---
LOCAL_DISPLAY=1
DISPLAY_SYNC=false

# --- Relay Twitch (RTMP) ---
# 1 = włącz gałąź pipeline → Twitch
RTMP_RELAY=0
# Klucz streamu — patrz lastmile/TWITCH_SETUP.md
TWITCH_STREAM_KEY=
# Domyślny ingest Twitch (nie zmieniaj bez powodu)
TWITCH_RTMP_URL=rtmp://live.twitch.tv/app

# Enkoder software (brak NVENC na Gigabyte)
X264_BITRATE_KBPS=3000
X264_KEYINT=60

# --- Portal sędziowski (iframe Twitch + ngrok) ---
# Nazwa kanału Twitch (bez twitch.tv/) — do embedu w portal/index.html
TWITCH_CHANNEL_VISION=
TWITCH_CHANNEL_QGC=

# --- Nadajnik (Jetson / dron) ---
UDP_DEST_HOST=192.168.100.249
UDP_DEST_PORT=5600

# --- Kompatybilność wsteczna (NIE używaj — migruj: gigabyte/migrate_config_to_twitch.sh) ---
# YOUTUBE_RELAY=0
# YOUTUBE_STREAM_KEY=
# YOUTUBE_RTMP_BASE=rtmp://a.rtmp.youtube.com/live2
